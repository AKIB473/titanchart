# ─────────────────────────────────────────────────────────────────────────────
# TitanChart Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
#
# SETUP:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values below
#   3. NEVER commit .env to git (it's in .gitignore)
#
# FOR CI/CD:
#   Add VITE_BOT_TOKEN and VITE_CHAT_ID as GitHub Secrets
#   (Settings → Secrets and variables → Actions)
# ─────────────────────────────────────────────────────────────────────────────

# Your Telegram Bot Token
# Get it from @BotFather → /newbot
VITE_BOT_TOKEN=your_bot_token_here

# The Telegram Chat ID where messages will be delivered
# Your personal ID, a group ID, or a channel ID
# Get your ID: message @userinfobot on Telegram
VITE_CHAT_ID=your_chat_id_here
